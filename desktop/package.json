{
  "name": "eventrun-pro-desktop",
  "version": "1.0.11",
  "description": "EventRun Pro desktop shell",
  "main": "src/main.js",
  "author": "Clube Piot",
  "scripts": {
    "dist:win": "electron-builder --win nsis",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.clubepiot.eventrunpro",
    "productName": "EventRun Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "updater.config.json"
    ],
    "extraResources": [
      {
        "from": "app-bundle",
        "to": "app-bundle"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "matheuspiot",
        "repo": "eventrun-pro",
        "releaseType": "release",
        "private": false
      }
    ],
    "win": {
      "artifactName": "EventRun.Pro.Setup.${version}.${ext}",
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "compression": "normal",
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
