generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  events    Event[]
  costItems CostItem[]
  marketingPackages MarketingPackage[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String       @unique
  username       String?      @unique
  role           UserRole     @default(ADMIN)
  passwordHash   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Event {
  id              String       @id @default(cuid())
  organizationId  String
  nomeEvento      String
  dataEvento      DateTime
  cidade          String
  estado          String
  localLargada    String
  organizador     String
  cnpjOrganizador String
  modalidades     String?
  distancias      String?
  capacidadeMaxima Int?
  limiteTecnico   String?
  cronogramaResumo String?
  patrocinadores  String?
  fornecedores    String?
  status          EventStatus  @default(PLANEJAMENTO)
  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  budget          EventBudget?
  regulation      RegulationConfig?
  operationTasks  EventOperationTask[]

  @@index([organizationId])
  @@index([dataEvento])
}

enum UserRole {
  ADMIN
  FINANCEIRO
  OPERACIONAL
  MARKETING
}

model EventOperationTask {
  id          String              @id @default(cuid())
  eventId     String
  fase        String
  titulo      String
  descricao   String?
  responsavel String?
  prazo       DateTime?
  lembreteEm  DateTime?
  status      OperationTaskStatus @default(PENDENTE)
  observacoes String?
  ordem       Int                 @default(0)
  criadoEm    DateTime            @default(now())
  atualizadoEm DateTime           @updatedAt
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([status])
}

enum OperationTaskStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

enum EventStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  FINALIZADO
}

model CostItem {
  id             String        @id @default(cuid())
  organizationId String
  nome           String
  categoria      CostCategory
  tipoCusto      CostType
  unidade        CostUnit
  custoPadrao    Float
  descricao      String?
  criadoEm       DateTime      @default(now())
  atualizadoEm   DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  budgetItems    EventBudgetItem[]

  @@index([organizationId])
  @@index([categoria])
}

enum CostCategory {
  ESTRUTURA
  STAFF
  SEGURANCA
  MATERIAIS
  COMUNICACAO
  TAXAS
  LOGISTICA
  OUTROS
}

enum CostType {
  FIXO
  VARIAVEL_ATLETA
  VARIAVEL_UNIDADE
}

enum CostUnit {
  UN
  PESSOA
  HORA
  KM
  LOTE
  ATLETA
}

model EventBudget {
  id                        String            @id @default(cuid())
  eventId                   String            @unique
  logoDataUrl               String?
  metaInscritos             Int
  patrocinioPrevisto        Float
  lucroAlvoPercentual       Float
  taxaPlataformaPercentual  Float
  impostoPercentual         Float
  taxaCancelamentoReembolsoPercentual Float    @default(0)
  criadoEm                  DateTime          @default(now())
  atualizadoEm              DateTime          @updatedAt
  event                     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items                     EventBudgetItem[]
}

model EventBudgetItem {
  id            String      @id @default(cuid())
  eventBudgetId String
  costItemId    String
  quantidade    Float
  valorUnitario Float
  tipoCusto     CostType
  eventBudget   EventBudget @relation(fields: [eventBudgetId], references: [id], onDelete: Cascade)
  costItem      CostItem    @relation(fields: [costItemId], references: [id], onDelete: Cascade)

  @@index([eventBudgetId])
  @@index([costItemId])
}

model RegulationConfig {
  id                       String   @id @default(cuid())
  eventId                  String   @unique
  templateTipo             String   @default("CORRIDA_RUA")
  possuiKids               Boolean  @default(false)
  possuiChip               Boolean  @default(true)
  possuiPremiacaoDinheiro  Boolean  @default(false)
  permiteTransferencia     Boolean  @default(false)
  permiteRetiradaTerceiros Boolean  @default(true)
  exigeAtestadoMedico      Boolean  @default(false)
  logoDataUrl              String?
  faixaEtariaInicio        Int      @default(18)
  faixaEtariaFim           Int      @default(80)
  intervaloFaixaEtaria     Int      @default(5)
  tempoLimiteMinutos       Int
  plataformaInscricao      String
  valorInscricao           Float
  limiteVagas              Int
  kitDescricao             String?
  premiacaoDescricao       String?
  regrasGeraisExtra        String?
  documentosObrigatorios   String?
  politicaCancelamento     String?
  emailContato             String
  whatsappContato          String
  dataInicioInscricao      DateTime
  dataFimInscricao         DateTime
  criadoEm                 DateTime @default(now())
  atualizadoEm             DateTime @updatedAt
  event                    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model MarketingPackage {
  id             String   @id @default(cuid())
  organizationId String
  nome           String
  descricao      String?
  entregaveis    String
  investimento   Float
  cronograma     String?
  ativo          Boolean  @default(true)
  ordem          Int      @default(0)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
